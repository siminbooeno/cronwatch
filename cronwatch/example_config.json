{
  "state_dir": "/tmp/cronwatch/state",
  "history_dir": "/tmp/cronwatch/history",
  "history_retention_days": 30,
  "check_interval_seconds": 60,
  "digest_interval_seconds": 86400,
  "alert": {
    "webhook_url": "https://hooks.example.com/cronwatch",
    "email_to": "ops@example.com",
    "email_from": "cronwatch@example.com",
    "smtp_host": "smtp.example.com",
    "smtp_port": 587
  },
  "jobs": [
    {
      "name": "nightly-backup",
      "command": "/usr/local/bin/backup.sh",
      "interval_seconds": 86400,
      "grace_seconds": 300,
      "tags": ["backup", "critical"]
    },
    {
      "name": "hourly-sync",
      "command": "/usr/local/bin/sync.sh",
      "interval_seconds": 3600,
      "grace_seconds": 120,
      "timeout_seconds": 600,
      "tags": ["sync"]
    },
    {
      "name": "health-ping",
      "command": "/usr/local/bin/ping-check.sh",
      "interval_seconds": 300,
      "tags": ["monitoring", "critical"]
    }
  ]
}
